{
  "name": "eden",
  "version": "0.1.0",
  "private": true,
  "description": "Emergent Digital Ecosystem Network - Artificial Society Engine",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "db:migrate": "pnpm --filter @eden/db migrate",
    "db:seed": "pnpm --filter @eden/db seed"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
